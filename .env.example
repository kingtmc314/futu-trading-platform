# OpenD 連線
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# 交易環境：SIMULATE（模擬）或 REAL（實盤，需 OpenD 解鎖交易）
FUTU_TRD_ENV=SIMULATE

# 預設交易市場：US / HK / CN / SG / MY / JP
FUTU_DEFAULT_MARKET=HK

# 可選：指定交易帳戶 ID（0 表示使用預設）
FUTU_ACC_ID=0

# 可選：券商标识 FUTUSECURITIES / FUTUINC / FUTUSG 等
# FUTU_SECURITY_FIRM=FUTUSECURITIES

# Web 控制台
WEB_HOST=127.0.0.1
WEB_PORT=8080
