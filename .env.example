# OpenD 連線
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# 交易環境：SIMULATE（模擬）或 REAL（實盤，需 OpenD 解鎖交易）
FUTU_TRD_ENV=SIMULATE

# 預設交易市場：US / HK / CN / SG / MY / JP
FUTU_DEFAULT_MARKET=HK

# 可選：指定交易帳戶 ID（0 表示使用預設）
FUTU_ACC_ID=0

# 可選：券商标识 FUTUSECURITIES / FUTUINC / FUTUSG 等
# FUTU_SECURITY_FIRM=FUTUSECURITIES

# Web 控制台
WEB_HOST=127.0.0.1
WEB_PORT=8080

# 實盤風控（預設關閉實盤下單）
FUTU_REAL_TRADING_ENABLED=false
FUTU_REAL_MAX_ORDER_VALUE=10000
FUTU_REAL_MAX_QUANTITY=1000
FUTU_REAL_ALLOWED_PREFIXES=HK,US
FUTU_REAL_MARKET_ORDER_ALLOWED=false

# World Monitor（預設只監控、評分、記錄，不會自動下單）
WORLD_MONITOR_ENABLED=true
WORLD_MONITOR_AUTO_TRADE=false
WORLD_MONITOR_INTERVAL_SECONDS=3600
WORLD_MONITOR_TRD_ENV=SIMULATE
WORLD_MONITOR_SYMBOLS=US.SPY,US.QQQ,HK.02800
WORLD_MONITOR_QUANTITY=1
WORLD_MONITOR_BUY_THRESHOLD=3.0
WORLD_MONITOR_SELL_THRESHOLD=-3.0
WORLD_MONITOR_DATA_DIR=data/world_monitor
WORLD_MONITOR_SOURCES=finance:https://feeds.finance.yahoo.com/rss/2.0/headline?s=%5EGSPC&region=US&lang=en-US,policy:https://www.federalreserve.gov/feeds/press_all.xml
